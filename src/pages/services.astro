---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | Do It"
  activePage="Services"
  description="Stop planning. Just Do It. We turn complex technical hurdles into streamlined digital reality."
>
  <section class="pt-36 pb-20 px-6 max-w-7xl mx-auto">
    <header
      class="mb-24 flex flex-col md:flex-row items-end justify-between gap-12 reveal"
    >
      <div class="max-w-3xl">
        <span
          class="text-accent uppercase tracking-widest text-xs font-bold mb-4 flex items-center gap-4"
        >
          <span class="w-16 h-[2px] bg-primary"></span>

          Actionable Technology
        </span>
        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-wide leading-tight text-on-surface mb-8"
        >
          Stop Planning<br />Just
          <span
            class="text-transparent bg-clip-text bg-linear-to-r from-on-secondary-container to-[#4675c0]"
          >
            Do It</span
          >
        </h1>
        <p class="text-on-surface-variant text-lg max-w-xl leading-relaxed">
          We turn complex technical hurdles into streamlined digital reality.
          Whether it's high-stakes engineering or brand evolution, if you need
          it solved, we Do It
        </p>
      </div>
      <div
        class="hidden lg:flex w-32 h-32 rounded-full border border-primary/20 items-center justify-center relative overflow-hidden"
      >
        <div class="absolute inset-0 bg-primary/5 blur-xl"></div>
        <span
          class="material-symbols-outlined text-accent text-4xl animate-pulse"
          >bolt</span
        >
      </div>
    </header>
    <div class="grid grid-cols-12 gap-6">
      <div
        class="col-span-12 md:col-span-7 glass-card p-10 rounded-xl relative group overflow-hidden reveal"
      >
        <div
          class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity"
        >
          <span class="material-symbols-outlined text-9xl">auto_fix_high</span>
        </div>
        <div class="relative z-10 h-full flex flex-col justify-between">
          <div>
            <div
              class="w-14 h-14 rounded-lg bg-surface-container-highest flex items-center justify-center mb-8 glow-icon"
            >
              <span
                class="material-symbols-outlined text-accent text-3xl"
                style="font-variation-settings: 'FILL' 1">palette</span
              >
            </div>
            <h3 class="text-3xl font-bold mb-4">Design? We Do It</h3>
            <p class="text-on-surface-variant max-w-md leading-relaxed">
              Aesthetics meet performance. We build visual languages that don't
              just look elite—they convert. From deep UX audits to high-fidelity
              motion systems
            </p>
          </div>
          <div
            class="mt-12 flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-accent"
          >
            <span>User Intent</span>
            <div class="w-1 h-1 rounded-full bg-outline-variant"></div>
            <span>Liquid Motion</span>
            <div class="w-1 h-1 rounded-full bg-outline-variant"></div>
            <span>Design Ops</span>
          </div>
        </div>
      </div>
      <div
        class="col-span-12 md:col-span-5 bg-surface-container-low p-10 rounded-xl border border-white/5 flex flex-col justify-center reveal"
      >
        <div
          class="w-14 h-14 rounded-lg bg-primary/15 flex items-center justify-center mb-8 glow-icon"
        >
          <span class="material-symbols-outlined text-accent text-3xl"
            >shopping_bag</span
          >
        </div>
        <h3 class="text-2xl font-bold mb-4">Scale? Let's Do It</h3>
        <p class="text-on-surface-variant leading-relaxed mb-8">
          Rapid-growth commerce systems for brands that move fast. We handle the
          transactions, you handle the success
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div
            class="p-4 bg-surface-container-highest rounded-lg text-sm font-semibold"
          >
            One-Click Flow
          </div>
          <div
            class="p-4 bg-surface-container-highest rounded-lg text-sm font-semibold"
          >
            Global Scale
          </div>
        </div>
      </div>
      <div
        class="col-span-12 md:col-span-5 glass-card p-10 rounded-xl border border-white/5 reveal"
      >
        <div
          class="w-14 h-14 rounded-lg bg-surface-container-highest flex items-center justify-center mb-8 glow-icon"
        >
          <span
            class="material-symbols-outlined text-accent text-3xl"
            style="font-variation-settings: 'FILL' 1">terminal</span
          >
        </div>
        <h3 class="text-2xl font-bold mb-4">Code? Consider It Done</h3>
        <p class="text-on-surface-variant leading-relaxed">
          Hardcore engineering for mission-critical applications. We ship clean,
          optimized, and indestructible code for the modern web
        </p>
        <div class="mt-8 space-y-4">
          <div
            class="h-px bg-gradient-to-r from-outline-variant/30 to-transparent"
          >
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="text-on-surface-variant">Rapid Deployment</span>
            <span class="text-accent material-symbols-outlined">done_all</span>
          </div>
          <div
            class="h-px bg-linear-to-r from-outline-variant/30 to-transparent"
          >
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="text-on-surface-variant">Legacy Refactoring</span>
            <span class="text-accent material-symbols-outlined">done_all</span>
          </div>
        </div>
      </div>
      <div
        class="col-span-12 md:col-span-7 bg-surface-container-highest p-10 rounded-xl relative overflow-hidden group reveal"
      >
        <img
          class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale group-hover:grayscale-0 group-hover:opacity-30 transition-all duration-700"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuB92G82a6SNdpzRNmB8fIKFNEawi7fMmcEImlVT1knhip2YU2wWSgiw-rgwacQ6X1JDgKOkeQLqNKpyUlainpbhYy7FxnvHt31ATZxYQkhacKb_vBUTT0wdHcVrhsVbS_sbcAZreH8e8QewuaQG-2SEGMXTjV_BH-pcn-5NVyrRYURNh6JpZdoEFOzse6a3PgLkDZ3dVUjdtFmPJVDu3QSN9uuNXINz5SycE1eqUB2nwjxl2HLdjcoqmbgyHzXrysxuwzyffOH6UQ"
          alt="Server network"
        />
        <div class="relative z-10 flex flex-col h-full justify-between">
          <div>
            <div
              class="w-14 h-14 rounded-lg bg-background/80 backdrop-blur-md flex items-center justify-center mb-8 glow-icon"
            >
              <span class="material-symbols-outlined text-accent text-3xl"
                >cloud_done</span
              >
            </div>
            <h3 class="text-3xl font-bold mb-4">Uptime? We Guarantee It</h3>
            <p class="text-on-surface-variant max-w-sm leading-relaxed mb-6">
              Zero-friction infrastructure. We manage the backbone of your
              digital presence so you never have to think about it again
            </p>
          </div>
          <div class="flex items-center gap-6">
            <a
              href="/contact"
              class="bg-white text-black px-8 py-3 rounded-full font-bold text-sm flex items-center gap-2 hover:bg-accent transition-colors"
            >
              Deploy Now
              <span class="material-symbols-outlined text-sm"
                >rocket_launch</span
              >
            </a>
          </div>
        </div>
      </div>
    </div>
    <section class="mt-32 reveal">
      <div class="flex flex-col md:flex-row gap-20 items-center">
        <div class="flex-1 space-y-8">
          <h2 class="text-4xl font-bold tracking-tight">
            The Do It Methodology
          </h2>
          <div class="space-y-12">
            {
              [
                {
                  num: "01",
                  title: "Cut the Noise",
                  desc: "We bypass endless workshops and get straight to auditing what actually works for your business",
                },
                {
                  num: "02",
                  title: "Build & Break",
                  desc: "Fast prototyping that tests the limits. We don't just design; we prove concepts in real-time",
                },
                {
                  num: "03",
                  title: "Ship & Conquer",
                  desc: "Continuous delivery cycles that keep you ahead of the curve. If it needs to be live, we Do It",
                },
              ].map((step) => (
                <div class="flex gap-6">
                  <div class="text-accent font-black text-xl">{step.num}</div>
                  <div>
                    <h4 class="font-bold text-xl mb-2">{step.title}</h4>
                    <p class="text-on-surface-variant leading-relaxed">
                      {step.desc}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div
          class="flex-1 w-full aspect-square bg-surface-container-low rounded-2xl relative overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-primary/5 to-transparent"
          >
          </div>
          <div
            class="absolute inset-12 border-2 border-primary/20 rounded-xl border-dashed"
          >
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div
              class="glass-card w-64 p-6 rounded-xl text-center space-y-4 shadow-2xl"
            >
              <div
                class="w-12 h-12 bg-primary mx-auto rounded-full flex items-center justify-center"
              >
                <span class="material-symbols-outlined text-on-primary"
                  >check_circle</span
                >
              </div>
              <div class="text-sm font-bold uppercase tracking-widest">
                Job Status
              </div>
              <div class="flex justify-center gap-1">
                <div class="w-2 h-8 bg-accent rounded-full"></div>
                <div class="w-2 h-12 bg-accent rounded-full"></div>
                <div class="w-2 h-10 bg-accent rounded-full"></div>
                <div class="w-2 h-14 bg-accent rounded-full"></div>
                <div class="w-2 h-8 bg-accent rounded-full"></div>
              </div>
              <div class="text-xs text-accent">Done &amp; Delivered</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
