---
import BaseLayout from "../layouts/BaseLayout.astro";
import { toast, Toaster } from "sonner";
---

<BaseLayout title="Do It | Engineering the Future" activePage="Home">


  <div class="relative z-10 w-full overflow-hidden text-white">
    <section
      id="hero-section"
      class="relative min-h-screen flex items-center justify-center bg-transparent"
    >
      <div class="relative z-10 max-w-7xl mx-auto px-8 text-center mt-0">
        <div
          class="inline-flex items-center gap-2 py-2 px-6 mb-10 rounded-full border border-white/10 bg-white/3 backdrop-blur-2xl text-white/80 select-none text-xs font-bold tracking-[0.3em] uppercase shadow-[0_0_30px_rgba(0,0,0,0.5)] animate-fade-up"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#10d164] opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-[#10d164] shadow-[0_0_10px_rgba(16,209,100)]"
            ></span>
          </span>
          Don't just dream it
        </div>

        <h1
          class="text-6xl md:text-8xl lg:text-[7.5rem] font-extrabold tracking-tighter mb-8 text-white animate-fade-up-delay-1 drop-shadow-2xl"
        >
          <span
            class="text-transparent w-full select-none leading-[1.1] bg-clip-text bg-linear-to-r from-on-secondary-container to-[#4675c0] animate-shimmer inline-block pt-2"
          >
            Simply<br /> Do It
          </span>
        </h1>

        <p
          class="max-w-2xl mx-auto text-[#ccc] select-none text-md md:text-lg font-bold mb-16 leading-relaxed animate-fade-up-delay-2"
        >
          Whatever the challenge, we Do It. From obsidian-tier technical
          architecture to fluid digital experiences, we turn complexity into
          action.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-6 justify-center items-center animate-fade-up-delay-3"
        >
          <a
            href="/contact"
            class="px-10 py-5 w-full sm:w-auto bg-white text-[#040914] rounded-full font-bold text-lg hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.4)] select-none transition-all duration-300 active:scale-95 group flex items-center justify-center gap-2"
          >
            Start Doing
            <span
              class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform"
              >arrow_forward</span
            >
          </a>
          <a
            href="/services"
            class="px-10 py-5 w-full sm:w-auto rounded-full font-bold text-lg text-white border border-white/10 bg-white/5 backdrop-blur-lg hover:bg-white/10 hover:border-white/30 transition-all duration-300 active:scale-95 flex items-center select-none justify-center"
          >
            See How We Do It
          </a>
        </div>
      </div>
    </section>
    <section class="md:py-32 relative bg-transparent">
      <div class="max-w-7xl mx-auto px-8 relative z-10">
        <div
          class="flex flex-col justify-between items-center mb-30 gap-10 reveal"
        >
          <h2
            class="text-xs font-black tracking-[0.6em] uppercase text-accent mb-4 flex items-center text-center gap-4"
          >
            <span
              class="block w-32 h-[2px] bg-linear-to-r from-transparent via-primary to-transparent rounded-full"
            ></span>
            Expertise to Do It right
            <span
              class="block w-32 h-[2px] bg-linear-to-l from-transparent via-primary to-transparent rounded-full"
            ></span>
          </h2>
          <div
            class="flex flex-col md:flex-row w-full justify-between items-center gap-10 reveal"
          >
            <div class="max-w-xl">
              <h3
                class="text-5xl md:text-6xl font-bold tracking-tight leading-tight select-none text-center md:text-start text-white"
              >
                Mastering the <br />Digital Craft
              </h3>
            </div>
            <p
              class="text(--color-on-surface-variant) max-w-sm text-[#ddd] text-base leading-relaxed font-light text-center md:text-start"
            >
              High-velocity delivery across complex enterprise ecosystems. If
              you can envision it, our team has the precision to Do It.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div
            class="glass-card bg-(--color-surface)/10 backdrop-blur-md p-10 rounded-[2rem] group glow-border border border-white/5 flex flex-col justify-center items-center md:items-start reveal"
          >
            <div
              class="mb-8 inline-flex p-4 rounded-2xl bg-primary/20 text-accent shadow-[0_0_15px_rgba(74,144,217,0.2)]"
            >
              <span
                class="material-symbols-outlined text-4xl"
                style="font-variation-settings: 'FILL' 1"
                >auto_awesome_motion</span
              >
            </div>
            <h4 class="text-2xl text-white font-bold mb-4 tracking-tight">
              Design It
            </h4>
            <p
              class="text(--color-on-surface-variant) text-sm leading-relaxed md:mb-8 opacity-70 text-center md:text-start"
            >
              Visual frameworks crafted with optical precision and fluid motion.
            </p>
          </div>
          <div
            class="glass-card bg-(--color-surface)/10 backdrop-blur-md p-10 rounded-[2rem] group glow-border border border-white/5 flex flex-col justify-center items-center md:items-start reveal"
          >
            <div
              class="mb-8 inline-flex p-4 rounded-2xl bg-primary/20 text-accent shadow-[0_0_15px_rgba(74,144,217,0.2)]"
            >
              <span
                class="material-symbols-outlined text-4xl"
                style="font-variation-settings: 'FILL' 1">terminal</span
              >
            </div>
            <h4 class="text-2xl text-white font-bold mb-4 tracking-tight">
              Build It
            </h4>
            <p
              class="text(--color-on-surface-variant) text-sm leading-relaxed md:mb-8 opacity-70 text-center md:text-start"
            >
              Scalable backend infrastructures paired with reactive frontend
              engines.
            </p>
          </div>
          <div
            class="glass-card bg-(--color-surface)/10 backdrop-blur-md p-10 rounded-[2rem] group glow-border border border-white/5 flex flex-col justify-center items-center md:items-start reveal"
          >
            <div
              class="mb-8 inline-flex p-4 rounded-2xl bg-primary/20 text-accent shadow-[0_0_15px_rgba(74,144,217,0.2)]"
            >
              <span
                class="material-symbols-outlined text-4xl"
                style="font-variation-settings: 'FILL' 1">shopping_bag</span
              >
            </div>
            <h4 class="text-2xl text-white font-bold mb-4 tracking-tight">
              Scale It
            </h4>
            <p
              class="text(--color-on-surface-variant) text-sm leading-relaxed md:mb-8 opacity-70 text-center md:text-start"
            >
              High-conversion e-commerce hubs optimized for global transaction
              speeds.
            </p>
          </div>
          <div
            class="glass-card bg-(--color-surface)/10 backdrop-blur-md p-10 rounded-[2rem] group glow-border border border-white/5 flex flex-col justify-center items-center md:items-start reveal"
          >
            <div
              class="mb-8 inline-flex p-4 rounded-2xl bg-primary/20 text-accent shadow-[0_0_15px_rgba(74,144,217,0.2)]"
            >
              <span
                class="material-symbols-outlined text-4xl"
                style="font-variation-settings: 'FILL' 1">cloud_done</span
              >
            </div>
            <h4 class="text-2xl text-white font-bold mb-4 tracking-tight">
              Host It
            </h4>
            <p
              class="text(--color-on-surface-variant) text-sm leading-relaxed md:mb-8 opacity-70 text-center md:text-start"
            >
              Obsidian-grade security and 99.9% uptime for enterprise
              ecosystems.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-40 relative overflow-hidden bg-transparent">
      <div class="max-w-7xl mx-auto px-8 relative z-10">
        <div class="flex flex-col items-center">
          <h2
            class="text-xs font-black tracking-[0.6em] text-center md:text-start select-none uppercase text-accent mb-20 flex items-center gap-4"
          >
            <span
              class="block w-32 h-[2px] bg-linear-to-r from-transparent via-primary/90 to-transparent rounded-full"
            ></span>
            Our Philosophy
            <span
              class="block w-32 h-[2px] bg-linear-to-l from-transparent via-primary/90 to-transparent rounded-full"
            ></span>
          </h2>
          <div class="grid grid-cols-12 gap-8 lg:gap-0 items-center">
            <div class="col-span-12 lg:col-span-6 z-20 pr-0 lg:pr-20 reveal">
              <div class="mb-10">
                <h3
                  class="text-6xl select-none md:text-8xl text-center md:text-start font-extrabold text-white tracking-tighter leading-[0.85] mb-12 uppercase drop-shadow-lg"
                >
                  Action is <br />
                  <span class="relative inline-block">
                    the
                    <span class="text-white/40 italic"> Only Way</span>
                  </span>
                </h3>
              </div>
              <div class="space-y-8 max-w-md">
                <p
                  class="text-on-surface-variant select-none text-center md:text-start text-xl font-light leading-relaxed"
                >
                  At Do It, we believe software shouldn't just exist—it should
                  perform. We don't settle for "good enough" because we have the
                  expertise to Do It right
                </p>
                <div
                  class="glass-card bg-white/2 select-none backdrop-blur-md p-6 rounded-2xl border-l-4 border-l-primary/60 group"
                >
                  <p
                    class="text-sm text-white/90 font-medium italic opacity-80 group-hover:opacity-100 transition-opacity"
                  >
                    "The Do It Standard is our commitment to zero-compromise
                    engineering across every digital touchpoint"
                  </p>
                </div>
                <div class="flex items-center gap-8 pt-4 select-none">
                  <div class="flex -space-x-4">
                    <div
                      class="w-12 h-12 rounded-full border-2 border-[#020408] bg-neutral-800 flex items-center justify-center overflow-hidden"
                    >
                      <div
                        class="w-full h-full bg-[radial-gradient(ellipse_at_top,rgba(74,144,217,0.8)_0%,rgba(26,58,107,0.5)_100%)]"
                      >
                      </div>
                    </div>
                    <div
                      class="w-12 h-12 rounded-full border-2 border-[#020408] bg-neutral-800 flex items-center justify-center"
                    >
                      <span
                        class="material-symbols-outlined text-xs text-accent"
                        >verified</span
                      >
                    </div>
                  </div>
                  <div
                    class="text-[10px] font-black uppercase tracking-[0.2em] text-white/50"
                  >
                    Trusted by those <br />who Do It better.
                  </div>
                </div>
              </div>
            </div>

            <div
              class="hidden md:flex select-none col-span-12 lg:col-span-6 mt-20 lg:mt-0 relative h-[600px] items-center justify-center reveal"
            >
              <div
                class="absolute w-full h-full aspect-square max-w-[500px] glass-panel bg-white/3 rounded-[2.5rem] -rotate-6 transform translate-x-10 translate-y-8 overflow-hidden border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)] group"
              >
                <img
                  alt="Cybersecurity interface background"
                  class="object-cover w-full h-full opacity-30 mix-blend-screen scale-120 group-hover:scale-100 transition-transform duration-1000"
                  src="
              https://static.vecteezy.com/system/resources/thumbnails/055/873/765/small_2x/abstract-digital-futuristic-design-ai-artificial-intelligence-ai-brain-technology-futuristic-illustration-and-concept-of-artificial-intelligence-vector.jpg"
                  alt=""
                />
              </div>
              <div>
                <div
                  class="relative w-full aspect-square max-w-[500px] glass-panel bg-white/3 backdrop-blur-xl rounded-[2.5rem] overflow-hidden border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)] group"
                >
                  <img
                    alt="Cybersecurity interface background"
                    class="object-cover w-full h-full opacity-30 mix-blend-screen scale-120 group-hover:scale-100 transition-transform duration-1000"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuB7zkDpbrrrhmCRjuqckCnSqWhp69RyWyY7BkXOQkJUed6A8OKZyKZRuvfQVdwQUHeAy9Sbg9uTCxdylLdRhBEH9bHPHU2_uiauFqES9QDRPc-wJDAvN0f87gYqyd99gAiwLpouvC_SMFVQcJEJo7sfhwrqgeMWzIP6D_h80_A3BaAX4u_QEvBXVC0BxdHgy3vxrQ6Q8tymqiZmUq1pUj4mvIThe4CWM6Y9BlU7BesXPSstHQrJZ-8wbQgep2qB1pGnAoUydDPYcQ"
                  />
                </div>
                <div
                  class="absolute bottom-10 left-10 right-10 glass-panel bg-black/40 backdrop-blur-2xl p-8 rounded-3xl border border-white/10 translate-y-4 group-hover:translate-y-0 transition-transform duration-700"
                >
                  <div class="flex justify-between items-start mb-6">
                    <div>
                      <div
                        class="text-4xl font-black text-white tracking-tighter"
                      >
                        100%
                      </div>
                      <div
                        class="text-[11px] uppercase tracking-[0.3em] font-bold text-accent"
                      >
                        Execution Focus
                      </div>
                    </div>
                    <div
                      class="h-10 w-10 rounded-full bg-primary/20 flex items-center justify-center animate-pulse shadow-[0_0_15px_rgba(74,144,217,0.4)]"
                    >
                      <span
                        class="material-symbols-outlined text-accent text-xl"
                        >rocket_launch</span
                      >
                    </div>
                  </div>
                  <div class="space-y-2">
                    <div
                      class="h-1 w-full bg-white/10 rounded-full overflow-hidden"
                    >
                      <div
                        class="h-full bg-linear-to-r from-primary to-accent w-full shadow-[0_0_10px_rgba(74,144,217,0.8)]"
                      >
                      </div>
                    </div>
                    <div
                      class="flex justify-between text-[10px] uppercase tracking-widest font-bold text-white/50"
                    >
                      <span>Done Right</span>
                      <span>Optimized</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="md:py-32 bg-transparent select-none">
      <div class="max-w-7xl mx-auto px-8 relative z-10">
        <h2
          class="text-center flex items-center justify-center gap-4 text-xs font-black tracking-[0.5em] uppercase text-accent mb-24 reveal"
        >
          <span
            class="block w-32 h-[2px] bg-linear-to-r from-transparent via-primary/90 to-transparent rounded-full"
          ></span>
          How we Do It
          <span
            class="block w-32 h-[2px] bg-linear-to-l from-transparent via-primary/90 to-transparent rounded-full"
          ></span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {
            [
              {
                num: "01",
                title: "Envision It",
                desc: "Deep analysis of the technical landscape and your boldest business objectives.",
              },
              {
                num: "02",
                title: "Map It",
                desc: "Systematic blueprinting using modular structures to ensure we Do It once and Do It right.",
              },
              {
                num: "03",
                title: "Do It",
                desc: "Rapid execution with continuous integration. This is where the magic happens.",
              },
              {
                num: "04",
                title: "Perfect It",
                desc: "Polishing the glass—fine-tuning performance until it meets the obsidian standard.",
              },
            ].map((step, i) => (
              <div class="relative group reveal">
                <div class="glass-card bg-(--color-surface)/5 backdrop-blur-xl p-10 rounded-[2.5rem] h-full border border-white/5 hover:border-primary/30 transition-colors flex flex-col justify-between shadow-2xl">
                  <div>
                    <div class="text-5xl font-black text-white/10 mb-6 group-hover:text-primary transition-colors">
                      {step.num}
                    </div>
                    <h5 class="text-xl font-bold text-white mb-4 tracking-tight">
                      {step.title}
                    </h5>
                    <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                      {step.desc}
                    </p>
                  </div>
                  <div class="mt-8 h-px w-0 bg-accent group-hover:w-full transition-all duration-500 shadow-[0_0_10px_rgba(74,144,217,0.8)]" />
                </div>
                {i < 3 && (
                  <div class="hidden md:block absolute top-1/2 -right-3 w-6 h-6 rounded-full bg-primary/20 blur-md pointer-events-none" />
                )}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-40 bg-transparent">
      <div class="max-w-4xl mx-auto px-8 relative z-10">
        <div
          class="glass-panel bg-[#020408]/60 backdrop-blur-3xl p-16 rounded-[3rem] relative overflow-hidden shadow-[0_0_100px_rgba(0,0,0,0.8)] border border-white/10 reveal"
        >
          <div
            class="absolute top-0 left-0 w-full h-[2px] bg-linear-to-r from-transparent via-accent to-transparent"
          >
          </div>
          <div class="text-center mb-16">
            <h2 class="text-4xl font-bold mb-6 text-white tracking-tight">
              Let's Do It Together
            </h2>
            <p class="text-on-surface-variant text-lg font-light">
              Connect with our team to start your next high-precision project
            </p>
          </div>
          <form
            class="space-y-8"
            id="challenge-form"
            action="https://formspree.io/f/mojpkjwz"
            method="POST"
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-3">
                <label
                  class="text-[10px] uppercase tracking-[0.3em] font-black text-accent ml-5 opacity-80"
                >
                  Who are you?
                </label>
                <input
                  name="sender_name"
                  required
                  class="w-full bg-white-[0.03] backdrop-blur-md border border-white/10 rounded-2xl px-8 py-3 text-white focus:ring-1 focus:ring-accent outline-none placeholder:text-neutral-500 transition-all shadow-inner"
                  placeholder="Your Name"
                  type="text"
                />
              </div>
              <div class="space-y-3">
                <label
                  class="text-[10px] uppercase tracking-[0.3em] font-black text-accent ml-5 opacity-80"
                >
                  Reach out
                </label>
                <input
                  name="sender_email"
                  required
                  class="w-full bg-white-[0.03] backdrop-blur-md border border-white/10 rounded-2xl px-8 py-3 text-white focus:ring-1 focus:ring-accent outline-none placeholder:text-neutral-500 transition-all shadow-inner"
                  placeholder="Email Address"
                  type="email"
                />
              </div>
            </div>

            <div class="space-y-3 relative" id="custom-dropdown-container">
              <label
                class="text-[10px] uppercase tracking-[0.3em] font-black text-accent ml-5 opacity-80"
              >
                Challenge Type
              </label>

              <input
                type="hidden"
                name="challenge_type"
                id="challenge_type_input"
                value=""
              />

              <button
                type="button"
                id="dropdown-button"
                class="w-full flex items-center justify-between bg-white/3 backdrop-blur-md border border-white/10 rounded-2xl px-8 py-3 text-white outline-none transition-all shadow-inner hover:bg-white/6"
              >
                <span
                  id="dropdown-selected-text"
                  class="text-neutral-500 text-left">What should we Do?</span
                >
                <span
                  class="material-symbols-outlined text-white/40 transition-transform duration-300"
                  id="dropdown-arrow">expand_more</span
                >
              </button>

              <div
                id="dropdown-menu"
                class="absolute z-50 left-0 right-0 top-[105%] opacity-0 pointer-events-none translate-y-[-10px] transition-all duration-300 bg-[#060a12]/90 backdrop-blur-2xl border border-white/10 rounded-2xl overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.5)] flex flex-col"
              >
                <ul class="py-2 text-white m-0">
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Design a System"
                  >
                    Design a System
                  </li>
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Build a Platform"
                  >
                    Build a Platform
                  </li>
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Build a Website"
                  >
                    Build a Website
                  </li>
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Build a Mobile App"
                  >
                    Build a Mobile App
                  </li>
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Host a Website"
                  >
                    Host a Website
                  </li>
                  <li
                    class="dropdown-option px-8 py-3 text-white/70 hover:text-white hover:bg-primary/20 cursor-pointer transition-colors"
                    data-value="Scale a Solution"
                  >
                    Scale a Solution
                  </li>
                </ul>
              </div>
            </div>

            <div class="space-y-3">
              <label
                class="text-[10px] uppercase tracking-[0.3em] font-black text-accent ml-5 opacity-80"
              >
                Briefing
              </label>
              <textarea
                name="briefing"
                required
                class="w-full bg-white-[0.03] backdrop-blur-md border border-white/10 rounded-2xl px-8 py-5 text-white focus:ring-1 focus:ring-accent outline-none placeholder:text-neutral-500 transition-all resize-none shadow-inner"
                placeholder="Tell us what you want to achieve..."
                rows="5"></textarea>
            </div>

            <button
              id="challenge-submit-btn"
              class="w-full py-3 bg-white text-primary rounded-2xl font-black text-lg uppercase tracking-widest hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:scale-[1.01] active:scale-[0.98] transition-all"
              type="submit"
            >
              Send It
            </button>
          </form>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
<script>
  import Swal from "sweetalert2";

  function setupChallengeForm() {
    const form = document.getElementById(
      "challenge-form",
    ) as HTMLFormElement | null;
    const submitBtn = document.getElementById(
      "challenge-submit-btn",
    ) as HTMLButtonElement | null;
    const actionInput = document.getElementById(
      "challenge_type_input",
    ) as HTMLInputElement | null;
    const selectedText = document.getElementById("dropdown-selected-text");
    const dropdownBtn = document.getElementById("dropdown-button");
    const dropdownMenu = document.getElementById("dropdown-menu");
    const dropdownArrow = document.getElementById("dropdown-arrow");
    const options = document.querySelectorAll(".dropdown-option");
    const container = document.getElementById("custom-dropdown-container");

    if (!form || !submitBtn) return;

    // --- منطق الدروب داون (Dropdown Logic) ---
    if (dropdownBtn && dropdownMenu) {
      dropdownBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdownMenu.classList.toggle("opacity-0");
        dropdownMenu.classList.toggle("pointer-events-none");
        dropdownMenu.classList.toggle("translate-y-[-10px]");
        dropdownArrow?.classList.toggle("rotate-180");
      });
    }

    options.forEach((option) => {
      option.addEventListener("click", () => {
        const val = option.getAttribute("data-value");
        if (selectedText) {
          selectedText.innerText = val || "";
          selectedText.classList.remove("text-neutral-500");
          selectedText.classList.add("text-white");
        }
        if (actionInput) actionInput.value = val || "";
        dropdownMenu?.classList.add(
          "opacity-0",
          "pointer-events-none",
          "translate-y-[-10px]",
        );
        dropdownArrow?.classList.remove("rotate-180");
      });
    });

    window.addEventListener("click", (e) => {
      if (container && !container.contains(e.target as Node)) {
        dropdownMenu?.classList.add(
          "opacity-0",
          "pointer-events-none",
          "translate-y-[-10px]",
        );
        dropdownArrow?.classList.remove("rotate-180");
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const originalBtnText = submitBtn.innerHTML;
      submitBtn.innerHTML = `<span class="inline-block animate-pulse">Sending..</span>`;
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.7";

      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: { Accept: "application/json" },
        });

        if (response.ok) {
          Swal.fire({
            icon: "success",
            title: "Signal Sent!",
            text: "Mission accepted We will contact you soon",
            timer: 3000,
            timerProgressBar: true,
            showConfirmButton: false,
            background: "#0a0f1a",
            color: "#ffffff",
            iconColor: "#4ade80",
            width: window.innerWidth < 768 ? "90%" : "400px",
            customClass: {
              popup: "glass-alert",
              title: "text-xl font-bold tracking-tight",
              htmlContainer: "text-sm opacity-80",
            },
          });

          form.reset();
          if (selectedText) {
            selectedText.innerText = "What should we Do?";
            selectedText.classList.add("text-neutral-500");
          }
          if (actionInput) actionInput.value = "";
        } else {
          throw new Error();
        }
      } catch (error) {
        Swal.fire({
          icon: "error",
          title: "Connection Lost",
          text: "Failed to transmit. Please try again.",
          timer: 3000,
          timerProgressBar: true,
          showConfirmButton: false,
          background: "#0a0f1a",
          color: "#ffffff",
          iconColor: "#ef4444",
          width: window.innerWidth < 768 ? "90%" : "400px",
          customClass: {
            popup: "glass-alert",
          },
        });
      } finally {
        submitBtn.innerHTML = originalBtnText;
        submitBtn.disabled = false;
        submitBtn.style.opacity = "1";
      }
    });
  }

  setupChallengeForm();
  document.addEventListener("astro:after-swap", setupChallengeForm);
</script>

