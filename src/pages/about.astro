<script>
  function setupTeamCardsTouch() {
    const personCards = document.querySelectorAll(".group\\/person");
    personCards.forEach((card) => {
      card.addEventListener("click", (e) => {
        const isTouch = window.matchMedia("(pointer: coarse)").matches;
        if (isTouch) {
          if (!card.classList.contains("mobile-active")) {
            e.preventDefault();
            e.stopPropagation();
            personCards.forEach((c) => c.classList.remove("mobile-active"));
            card.classList.add("mobile-active");
          }
        }
      });
    });
    document.addEventListener("click", (e) => {
      const target = e.target as Element;
      if (!target.closest(".group\\/person")) {
        personCards.forEach((c) => c.classList.remove("mobile-active"));
      }
    });
  }
  setupTeamCardsTouch();
  document.addEventListener("astro:after-swap", setupTeamCardsTouch);
</script>
