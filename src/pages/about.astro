---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<style is:global>
  .group\/person.mobile-active img {
    filter: grayscale(0) !important;
    transform: scale(1.05) !important;
  }

  .group\/person.mobile-active a {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }
</style>
<BaseLayout
  title="About Us | Do It"
  activePage="About"
  description="The team that knows how to Do It. Learn about our philosophy, mission, and the doers behind Do It."
>
  <section class="relative px-8 max-w-7xl mx-auto pt-36 pb-20">
    <div
      class="absolute -top-20 right-0 w-80 h-80 bg-primary/15 blur-[100px] rounded-full pointer-events-none"
    >
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10 reveal">
        <span
          class="text-[10px] uppercase tracking-[0.2em] font-bold text-accent flex items-center gap-4 mb-6"
        >
          <span class="w-16 h-[2px] bg-primary"></span>
          Execution Without Compromise</span
        >

        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-wide leading-none mb-8 md:w-[80%]"
        >
          The Team That Knows How To
          <span
            class="text-transparent bg-clip-text bg-linear-to-r from-on-secondary-container to-[#4675c0]"
            >Do It</span
          >
        </h1>
        <p
          class="text-on-surface-variant text-xl md:text-2xl max-w-2xl font-light leading-relaxed"
        >
          At Do It, we bridge the gap between vision and reality, We are the
          specialists who prioritize finished products over promises and
          flawless execution over excuses
        </p>
      </div>
    </div>
  </section>

